# M3.4: 执行镜像（在轻量 worker 镜像基础上叠加 JDK + Maven 编译环境）
# 用于 fix_issue 和 gen_tests 任务（需运行 mvn test / npm test）
FROM maven:3.9.9-eclipse-temurin-21-jammy AS buildtools

FROM dtworkflow-worker:latest AS base

# 基础镜像以 USER worker 结尾，安装系统包需切回 root
USER root

# Java/Maven 工具链：bookworm 默认源不提供 openjdk-21，直接从 Maven 官方镜像复制。
COPY --from=buildtools /opt/java/openjdk /opt/java/openjdk
COPY --from=buildtools /usr/share/maven /usr/share/maven
ENV JAVA_HOME="/opt/java/openjdk"
ENV MAVEN_HOME="/usr/share/maven"
ENV PATH="${JAVA_HOME}/bin:${PATH}"
RUN java -version >/dev/null \
    && ln -s "${MAVEN_HOME}/bin/mvn" /usr/local/bin/mvn.real

# Maven/Gradle/npm 缓存目录预创建（named volume 挂载时 Docker 会复制此结构及权限）
RUN mkdir -p /workspace/.m2/repository /workspace/.gradle /workspace/.npm \
    && chown -R worker:worker /workspace

# mvn 包装器：强制 -Dmaven.repo.local=/workspace/.m2/repository，过滤 Claude 可能传入的覆盖参数。
# 烘焙到镜像的原因：容器 /tmp 为 noexec tmpfs，entrypoint 无法在运行时把包装器写到可执行位置。
# 镜像层自带的 /usr/local/bin/mvn 不受运行时挂载 noexec 影响，PATH 中优先命中本包装器。
# 构建期执行 `mvn --version` 作为烟囱测试：语法错 / mvn.real 链接损坏会让构建直接失败。
COPY build/docker/mvn-wrapper.sh /usr/local/bin/mvn
RUN chmod 0755 /usr/local/bin/mvn \
    && /usr/local/bin/mvn --version >/dev/null

ENV MAVEN_OPTS="-Dmaven.repo.local=/workspace/.m2/repository"
ENV GRADLE_USER_HOME="/workspace/.gradle"

# 切回非 root 用户（与基础镜像保持一致）
USER worker
