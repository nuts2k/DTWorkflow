# DTWorkflow Worker 镜像
# 基于 Node.js + Claude Code CLI + Git
# 生产环境建议锁定精确版本
ARG CLAUDE_CODE_VERSION=2.1.81
FROM node:20.18.0-bookworm-slim

# FROM 之后重新声明 ARG，使其在当前构建阶段可用
ARG CLAUDE_CODE_VERSION

# 安装 Git 和常用工具
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        git \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}

# 添加非 root 用户以提升容器安全性
RUN useradd -m worker

# 创建工作目录并设置权限（确保 worker 用户可读写）
RUN mkdir -p /workspace && chown worker:worker /workspace

# 添加入口脚本（在切换用户前添加，确保权限正确）
COPY --chmod=755 build/docker/entrypoint.sh /usr/local/bin/entrypoint.sh

# 工作目录
WORKDIR /workspace

# 以非 root 用户运行
USER worker

# 配置 Git（必须在 USER worker 之后执行，确保 .gitconfig 属于 worker 用户）
RUN git config --global user.name "DTWorkflow Bot" && \
    git config --global user.email "dtworkflow@noreply.local" && \
    git config --global init.defaultBranch main

# 入口点：先执行仓库 clone/checkout，再执行传入的 claude 命令
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
