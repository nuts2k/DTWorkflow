# DTWorkflow Worker 镜像
# 基于 Node.js + Claude Code CLI + Git
FROM node:20.18.0-bookworm-slim

# 安装 Git 和常用工具
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        git \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

# TODO: 发布正式版前更新 claude-code 版本
RUN npm install -g @anthropic-ai/claude-code@0.2

# 添加非 root 用户以提升容器安全性
RUN useradd -m worker

# 工作目录
WORKDIR /workspace

# 以非 root 用户运行
USER worker

# 配置 Git（必须在 USER worker 之后执行，确保 .gitconfig 属于 worker 用户）
RUN git config --global user.name "DTWorkflow Bot" && \
    git config --global user.email "dtworkflow@noreply.local" && \
    git config --global init.defaultBranch main

# 默认入口点（由 Pool.Run 覆盖 Cmd）
ENTRYPOINT ["claude"]
