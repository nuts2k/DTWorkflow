# DTWorkflow PoC - 环境变量示例文件
# 复制此文件为 .env 并填入真实值：cp .env.example .env

# Anthropic API Key（必填）
# 从 https://console.anthropic.com/account/keys 获取
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic API Base URL（可选，使用代理时填写）
# 默认为 https://api.anthropic.com，如使用代理网关请修改为代理地址
# ANTHROPIC_BASE_URL=http://127.0.0.1:15800
